# Cleartable server environment variables
# Copy this file to .env and fill in real values for local development.
# In production (Railway), these are set via the Railway dashboard.

# === Postgres ===
# Local dev: matches docker-compose.yml at repo root
# Run `docker compose up -d db` to start a local PG, then this URL just works.
# In production, Railway auto-injects DATABASE_URL from the attached PG addon.
DATABASE_URL=postgres://cleartable:cleartable_dev@localhost:5432/cleartable

# === OpenAI ===
# The reliable baseline + automatic fallback for every AI call. Still the
# primary for the heavy reasoning ops (Process Inbox, Weekly Review, etc.).
OPENAI_API_KEY=sk-...

# === Groq (free, fast) ===
# Primary provider for Smart Capture: ~4x faster than gpt-4o-mini at equal
# quality, free tier, and does NOT train on API data. Falls back to OpenAI
# automatically on error / rate-limit. Get a key (no card) at console.groq.com.
# If unset, Smart Capture transparently uses the OpenAI fallback instead.
GROQ_API_KEY=gsk_...

# === Google OAuth ===
# Get from Google Cloud Console -> APIs & Services -> Credentials.
# Authorized JavaScript origins must include http://localhost:5173..5176
# for local Vite dev (Vite falls back ports if 5173 is taken).
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# === Auth ===
# Any sufficiently long random string. Used to sign JWTs.
# Rotate this and all sessions invalidate.
JWT_SECRET=change-me-to-a-long-random-string

# === Optional ===
# Server port (defaults to 3000 if unset; production tends to land on 3001)
# PORT=3001
